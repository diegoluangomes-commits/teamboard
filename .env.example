# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=troque_por_uma_chave_longa_e_aleatoria

# ── PostgreSQL (Render) ────────────────────────────────────
# Copie a "Internal Database URL" do painel do Render
DATABASE_URL=postgresql://usuario:senha@host/teamboard

# ── Google OAuth (opcional — para criar reuniões Meet) ─────
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=https://SEU-APP.onrender.com/auth/google/callback

# ── E-mail SMTP (opcional — para notificações) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@gmail.com
SMTP_PASS=senha_de_app_16_digitos
